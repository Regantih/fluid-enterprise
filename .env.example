# Fluid Enterprise — Environment Variables
# Copy this file to .env.local and fill in values

# Database path (defaults to ./fluid.db if not set)
DATABASE_URL=./fluid.db

# Company ID to use (defaults to comp_acme_global seed data)
DEFAULT_COMPANY_ID=comp_acme_global

# Optional: Anthropic API key for live AI capability simulation
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: NextAuth secret for multi-user auth (future)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
