# Fluid Enterprise — Environment Variables
# Copy to .env and fill in your values

# Database (Postgres 17 + pgvector)
DATABASE_URL=postgresql://fluid:fluid_dev_2026@localhost:5432/fluid_enterprise

# Redis (for Signal Bus)
REDIS_URL=redis://localhost:6379/0

# Anthropic API (required for Checkpoint 3+)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Web app port
WEB_PORT=5000

# API port
API_PORT=8000
